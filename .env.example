# Copy this file to .env.local and fill in the values you have.
# Nothing here is required to run the template — without it, checkout runs
# in demo mode (no real charges), the Admin Studio stays disabled, and
# everything else works as-is.

# Admin Studio (/admin) — the visual cockpit for configuring the store.
# Pick a long passphrase (12+ characters). The studio is DISABLED until this
# is set, and its file-editing only works while running `npm run dev` locally.
ADMIN_PASSWORD=

# Public site URL — used for canonical tags, Open Graph images, JSON-LD,
# sitemap.xml and robots.txt. On Vercel this resolves automatically from the
# deployment URL, so the store already has correct SEO from the first deploy.
#
# Set this only once you point a CUSTOM DOMAIN at the store, so those URLs use
# your real domain instead of the *.vercel.app one. Steps:
#   1. Buy a domain (Namecheap, Cloudflare, Google Domains, …).
#   2. In your host (Vercel → Settings → Domains) add the domain; it shows the
#      exact DNS records to create — usually a CNAME on "www" and an A record
#      (or ALIAS) on the apex. Add them at your registrar; HTTPS is automatic.
#   3. Set the line below to the domain you want as canonical (scheme, no
#      trailing slash) in the host's env vars, and redeploy.
# NEXT_PUBLIC_SITE_URL=https://your-store.com

# Stripe — enables real Checkout. Get a test key from https://dashboard.stripe.com/test/apikeys
# Leave blank to keep checkout in demo mode.
STRIPE_SECRET_KEY=
